# Port the bridge listens on
PORT=7717

# Comma-separated list of allowed CORS origins (frontend dev/prod URLs)
CORS_ORIGINS=http://localhost:5173,http://localhost:8080,http://127.0.0.1:5173

# AES-256 key used to encrypt stored credentials at rest. 32 chars.
# Generate with: openssl rand -hex 16
CRED_KEY=change-me-to-a-32-char-secret-key

# Hard limit on per-query execution time (ms).
QUERY_TIMEOUT_MS=30000

# Block DROP / TRUNCATE / DELETE-without-WHERE when true.
SAFE_MODE=true